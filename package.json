{
  "name": "zcode-vision",
  "version": "0.1.1",
  "description": "Script-assisted vision model selection for ZCode sessions.",
  "type": "module",
  "bin": {
    "zcode-vision-models": "./scripts/zcode-vision-models.mjs"
  },
  "files": [
    ".zcode-plugin",
    "commands",
    "data",
    "docs",
    "marketplace.json",
    "scripts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "models": "node ./scripts/zcode-vision-models.mjs",
    "test": "node --test tests/*.test.mjs",
    "pack:check": "npm pack --dry-run",
    "zcode:check-marketplace": "node /Applications/ZCode.app/Contents/Resources/glm/zcode.cjs plugins list --json"
  },
  "keywords": [
    "zcode",
    "zcode-plugin",
    "vision",
    "visual-judgment",
    "image-analysis",
    "screenshot",
    "skill"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeZZard/zcode-vision.git"
  },
  "homepage": "https://github.com/WeZZard/zcode-vision#readme",
  "bugs": {
    "url": "https://github.com/WeZZard/zcode-vision/issues"
  }
}
