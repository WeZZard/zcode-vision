{
  "name": "zcode-vision",
  "version": "0.1.0",
  "description": "Vision routing for text-only ZCode sessions using configured image-capable ZCode models.",
  "type": "module",
  "bin": {
    "zcode-vision-models": "./scripts/zcode-vision-models.mjs",
    "zcode-vision-mcp": "./mcp/zcode-vision-server.mjs"
  },
  "files": [
    ".zcode-plugin",
    "commands",
    "docs",
    "mcp",
    "scripts",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "models": "node ./scripts/zcode-vision-models.mjs",
    "mcp": "node ./mcp/zcode-vision-server.mjs",
    "test": "node --test tests/*.test.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "zcode",
    "zcode-plugin",
    "vision",
    "visual-judgment",
    "image-analysis",
    "screenshot",
    "skill",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeZZard/zcode-vision.git"
  },
  "homepage": "https://github.com/WeZZard/zcode-vision#readme",
  "bugs": {
    "url": "https://github.com/WeZZard/zcode-vision/issues"
  }
}
